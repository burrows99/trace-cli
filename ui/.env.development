# Dev only: `next dev` (port 3000) calls the collector API on its own port. The collector
# sends `access-control-allow-origin: *`, so cross-origin dev fetches + SSE work out of the box.
# Production builds (`next build`) omit this, so the exported UI talks to its own origin — the
# collector that serves it. Start the API with:  trace serve   (defaults to :4000)
NEXT_PUBLIC_TRACE_API=http://localhost:4000
