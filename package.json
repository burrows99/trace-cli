{
  "name": "trace-cli",
  "version": "0.3.0",
  "description": "Unified, language-agnostic execution tracer & analyzer. One JSON envelope across breakpoint traces (Node/Chrome via CDP, Python via DAP/debugpy) and static analysis. A thin orchestration shell over battle-tested debug protocols. Usable by any agent, human, or script.",
  "type": "module",
  "bin": {
    "trace": "bin/trace"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "skills",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "trace": "node bin/trace",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1071.0",
    "@vscode/debugadapter-testsupport": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "chrome-remote-interface": "^0.34.0",
    "commander": "^12.1.0",
    "source-map": "^0.7.4"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "debugger",
    "breakpoint",
    "trace",
    "node-inspector",
    "cli",
    "agent"
  ],
  "license": "MIT",
  "author": "Raunak Burrows",
  "repository": {
    "type": "git",
    "url": ""
  }
}
