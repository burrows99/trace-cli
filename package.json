{
  "name": "trace-cli",
  "version": "0.1.0",
  "description": "General-purpose execution tracer over the Chrome DevTools Protocol — set breakpoints, fire a trigger, get a full execution trace. Works against a Node inspector or a Chrome page. Usable by any agent, human, or script.",
  "type": "module",
  "bin": {
    "trace": "bin/trace"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "skills",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "trace": "node bin/trace",
    "test": "node --test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "source-map": "^0.7.4"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "debugger",
    "breakpoint",
    "trace",
    "node-inspector",
    "cli",
    "agent"
  ],
  "license": "MIT",
  "author": "Raunak Burrows",
  "repository": {
    "type": "git",
    "url": ""
  }
}
