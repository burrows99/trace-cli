{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/burrows99/trace-cli/schema/trace.schema.json",
  "title": "trace envelope",
  "description": "The single output contract for every `trace` subcommand. Only `data` varies by command; `data` is composed from the shared shapes in $defs so consumers learn one vocabulary.",
  "type": "object",
  "required": ["tool", "version", "command", "ok", "meta", "target", "data", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "tool": { "const": "trace" },
    "version": { "type": "string" },
    "command": {
      "type": "string",
      "description": "dotted command id, e.g. dynamic.node, static.complexity, exec, web, correlate"
    },
    "ok": { "type": "boolean" },
    "meta": {
      "type": "object",
      "required": ["at"],
      "properties": {
        "at": { "type": "string", "format": "date-time" },
        "sessionId": { "type": "string", "description": "groups every event of this run; the unit of cross-source correlation" },
        "args": { "type": "object" },
        "durationMs": { "type": ["number", "null"] },
        "toolVersions": {
          "type": "object",
          "description": "provenance of the backing OSS tool(s) used",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "target": {
      "type": ["object", "null"],
      "description": "command-specific descriptor of what was analyzed or run (paths, port, url, cmd)"
    },
    "data": {
      "type": "object",
      "description": "command-specific payload, composed from $defs shapes"
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/Diagnostic" }
    }
  },
  "$defs": {
    "Loc": {
      "type": "object",
      "required": ["file"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "col": { "type": "integer" },
        "endLine": { "type": "integer" },
        "symbol": { "type": "string" },
        "lang": { "type": "string" }
      }
    },
    "Metric": {
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name": { "type": "string" },
        "value": { "type": ["number", "string"] },
        "unit": { "type": "string" }
      }
    },
    "Symbol": {
      "type": "object",
      "required": ["name", "kind", "loc"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "loc": { "$ref": "#/$defs/Loc" },
        "signature": { "type": "string" },
        "metrics": { "type": "array", "items": { "$ref": "#/$defs/Metric" } }
      }
    },
    "Graph": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "kind": { "type": "string" },
              "label": { "type": "string" },
              "loc": { "$ref": "#/$defs/Loc" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "kind": { "type": "string" },
              "weight": { "type": "number" }
            }
          }
        }
      }
    },
    "Event": {
      "type": "object",
      "required": ["seq", "kind"],
      "description": "the timeline primitive: a breakpoint hit, a span, or a UI action",
      "properties": {
        "seq": { "type": "integer" },
        "t": { "type": ["number", "string"], "description": "elapsed ms or ISO timestamp" },
        "kind": { "type": "string" },
        "label": { "type": "string" },
        "source": { "enum": ["cdp", "terminal", "otel"], "description": "the collector that produced this event" },
        "sessionId": { "type": "string", "description": "groups events of one run; shared across collectors for correlation" },
        "loc": { "$ref": "#/$defs/Loc" },
        "attrs": { "type": "object" },
        "traceId": { "type": "string" },
        "spanId": { "type": "string" },
        "parentSpanId": { "type": "string" }
      }
    },
    "Lineage": {
      "type": "object",
      "description": "derived: how one watched value mutated across the event timeline (value-over-time)",
      "required": ["name", "kind", "series"],
      "properties": {
        "name": { "type": "string" },
        "kind": { "enum": ["expr", "local"] },
        "occurrences": { "type": "integer" },
        "changes": { "type": "integer" },
        "series": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["seq", "value"],
            "properties": {
              "seq": { "type": "integer" },
              "t": { "type": ["number", "string"] },
              "loc": { "$ref": "#/$defs/Loc" },
              "value": {},
              "changed": { "type": "boolean" }
            }
          }
        }
      }
    },
    "Recording": {
      "type": "object",
      "description": "a trace artifact (e.g. the Chrome debug-replay video): a `url` when uploaded to S3, else a local `path`",
      "properties": {
        "url": { "type": "string" },
        "path": { "type": "string" },
        "bytes": { "type": "integer" }
      }
    },
    "Diagnostic": {
      "type": "object",
      "required": ["level", "code", "message"],
      "properties": {
        "level": { "enum": ["info", "warn", "error"] },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
